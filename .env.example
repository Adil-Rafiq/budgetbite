# ─── Database (packages/database) ───
DATABASE_URL=
DIRECT_DATABASE_URL=

# ─── API (apps/api) ───
API_PORT=3001
API_URL=http://localhost:3001

WEB_URL=http://localhost:3000

# Comma-separated additional allowed origins (e.g. preview deploys).
# These are honored by both CORS and better-auth trustedOrigins.
WEB_URL_ALLOWLIST=
# Optional regex matched against the request Origin. Honored by CORS only
# (auth flows must use a concrete origin from WEB_URL_ALLOWLIST).
# Example for Vercel previews:
# ^https://my-app-[a-z0-9-]+-myteam\.vercel\.app$
WEB_URL_PATTERN=

# Cross-site cookie config — pick AT MOST ONE based on your deploy topology:
#   - CROSS_SITE_COOKIES=true: web and API on different sites
#     (e.g. web on *.vercel.app, API on *.onrender.com). Requires HTTPS on the API.
#   - COOKIE_DOMAIN=.example.com: web and API share a parent domain
#     (e.g. app.example.com + api.example.com).
CROSS_SITE_COOKIES=
COOKIE_DOMAIN=

BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# used by other services to authenticate with the API
ADMIN_API_KEY=

# Number of reverse-proxy hops in front of the API, used for `trust proxy` so
# the rate limiter sees the real client IP. Leave 0 locally; set to 1 on Render
# (or however many proxies sit in front). Never use a permissive value here.
TRUST_PROXY_HOPS=0

# Per-IP rate limit on application routes (/api/*, excluding /api/auth which
# better-auth limits itself). Service-key callers (the scraper) are exempt.
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev

# Budget Plan Settings
AUTO_GENERATE_ON_CREATE=true
REPLAN_CUMULATIVE_DEVIATION_RATIO_THRESHOLD=0.4
NEARBY_RADIUS_KM=5
MAX_RESTAURANTS=20
MAX_ITEMS_PER_RESTAURANT=15

# AI
AI_PROVIDER=google
AI_MODEL_NAME=gemini-2.5-flash
AI_API_KEY=
AI_GENERATION_TEMPERATURE=0.3
AI_GENERATION_MAX_TOKENS=8192
AI_GENERATION_MAX_RETRIES=2

# ─── Web (apps/web) ───
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_WEB_URL=http://localhost:3000

# Set only in production (Vercel). When set, the web app proxies /api/* to
# this origin so the browser sees a single origin and the better-auth session
# cookie is stored against the web domain. Leave unset locally — the dev
# setup calls the API directly via NEXT_PUBLIC_API_URL=http://localhost:3001.
API_PROXY_TARGET=