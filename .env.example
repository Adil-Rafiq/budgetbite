# BudgetBite – copy to .env and fill in values

# Database (used by packages/database at runtime)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Direct DB URL for Drizzle migrations (often same as DATABASE_URL or non-pooled)
DIRECT_DATABASE_URL=postgresql://user:password@host:5432/dbname

# API
API_PORT=3001
API_URL=http://localhost

# Auth (JWT signing)
JWT_SECRET=your-secret-at-least-32-chars

# Admin / Scraper API (X-API-Key header; required for POST/PATCH/DELETE on /api/admin/*)
ADMIN_API_KEY=your-admin-api-key

# Scraper: API base URL when uploading (default http://localhost:3001)
# BUDGETBITE_API_URL=http://localhost:3001
